{
	"name": "bloglist-root",
	"private": true,
	"version": "1.0.0",
	"scripts": {
		"dev:backend": "npm --prefix bloglist-backend run dev",
		"dev:frontend": "npm --prefix bloglist-frontend run dev",
		"dev:full": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
		"test:backend": "npm --prefix bloglist-backend test",
		"test:frontend": "npm --prefix bloglist-frontend test",
		"test": "npm run test:backend && npm run test:frontend",
		"lint": "npm --prefix bloglist-frontend run lint"
	},
	"devDependencies": {
		"concurrently": "^9.2.1"
	}
}
